{
	"name": "reinamanager",
	"private": true,
	"version": "0.21.6",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev-cdp": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-cdp.ps1",
		"typecheck": "tsgo -b --noEmit",
		"format": "biome format --write .",
		"lint": "biome check .",
		"check": "pnpm run format && pnpm run lint && pnpm run typecheck",
		"changelog": "git-cliff --bump --unreleased --prepend CHANGELOG.md",
		"changelog:all": "git-cliff -o CHANGELOG.md",
		"changelog:view": "git-cliff --latest",
		"i18n:status": "i18next-cli status",
		"i18n:sync": "i18next-cli sync",
		"i18n:extract": "i18next-cli extract",
		"i18n:defaults": "node scripts/checkI18nDefaults.js",
		"i18n:defaults:write": "node scripts/checkI18nDefaults.js --write-missing"
